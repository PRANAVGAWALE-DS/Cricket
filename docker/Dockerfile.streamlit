FROM python:3.11-slim

WORKDIR /app

COPY requirements_tier3.txt .
RUN pip install --no-cache-dir -r requirements_tier3.txt

COPY streamlit_app.py .

ENV PYTHONPATH=/app

CMD ["streamlit", "run", "streamlit_app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true"]