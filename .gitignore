# =============================================================================
# Cricket ML — .gitignore
# =============================================================================

# ── Data (too large for GitHub) ───────────────────────────────────────────────
data/raw/
data/processed/

# ── Saved model artefacts ─────────────────────────────────────────────────────
# All model files are regenerated by running the training notebooks.
models/*.pkl
models/*.ubj
models/*.pt

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
venv_Cricket/
venv/
.venv/
env/

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Notebooks chart output ────────────────────────────────────────────────────
notebooks/.charts/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Coverage ──────────────────────────────────────────────────────────────────
coverage.xml
.coverage
htmlcov/

# ── Pytest ────────────────────────────────────────────────────────────────────
.pytest_cache
project_tree.txt
